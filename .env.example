# ===== LOS — переменные окружения =====
# Скопируй в .env (локально) или внеси в Replit → Secrets.
# Бот запустится, даже если заполнен только TELEGRAM_BOT_TOKEN,
# но для полноценной работы нужен ещё OPENAI_API_KEY.

# --- Обязательно ---
TELEGRAM_BOT_TOKEN=        # @BotFather → /newbot

# --- «Мозги» (без него бот не понимает свободный текст) ---
ANTHROPIC_API_KEY=        # console.anthropic.com → API Keys
ANTHROPIC_MODEL=claude-opus-4-8

# --- Голос (Whisper). Нужен только для голосовых сообщений ---
OPENAI_API_KEY=           # platform.openai.com → API Keys

# --- Опционально ---
# Хранилище — SQLite-файл по умолчанию (los_data.db), ничего задавать не нужно.
OURA_ACCESS_TOKEN=        # cloud.ouraring.com/personal-access-tokens
# Google Календарь обычно подключают командой /calendar (секретная iCal-ссылка),
# но можно и здесь:
GOOGLE_CALENDAR_ICS_URL=

# --- Настройки ---
LOS_TIMEZONE=Europe/Moscow
# Чат для проактивных сообщений (брифинг/напоминания), если не хочешь
# полагаться на /start. Обычно это chat_id Ани. Можно оставить пустым.
LOS_CHAT_ID=
