run = "python main.py"
entrypoint = "main.py"
modules = ["nodejs-20", "web", "python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[deployment]
run = ["python", "main.py"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 5003
externalPort = 3003

[[ports]]
localPort = 5004
externalPort = 4200

[[ports]]
localPort = 5005
externalPort = 5000

[[ports]]
localPort = 5006
externalPort = 5173

[[ports]]
localPort = 5007
externalPort = 6000

[[ports]]
localPort = 5008
externalPort = 6800

[[ports]]
localPort = 8001
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start_miniapp.sh"
waitForPort = 5000

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["python_anthropic_ai_integrations:1.0.0"]

[userenv]

[userenv.shared]
LOS_TIMEZONE = "Europe/Moscow"
LOS_DB_PATH = "los_miniapp.db"
