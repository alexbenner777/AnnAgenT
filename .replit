run = "python main.py"
entrypoint = "main.py"

[nix]
channel = "stable-25_05"

[deployment]
run = ["python", "main.py"]
deploymentTarget = "background"

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start_miniapp.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
